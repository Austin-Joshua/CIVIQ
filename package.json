{
  "name": "civiq",
  "private": true,
  "description": "CIVIQ fullstack: React (Next.js) + Go + MongoDB",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run api\"",
    "api": "cd backend && go run ./cmd/server",
    "build:api": "cd backend && go build -o civiq-api ./cmd/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
