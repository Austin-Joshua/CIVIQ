# Server-side: where Next.js proxies /api/* (Go API). Defaults work for local dev.
API_PROXY_TARGET=http://127.0.0.1:5000/api

# Browser: same-origin API via Next proxy (recommended). Optional override for tooling.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Go API has no Socket.IO by default — keep false unless you run a WS gateway.
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
NEXT_PUBLIC_SOCKET_URL=http://localhost:5001

NEXT_PUBLIC_AI_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=
