generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Organization {
  id               String   @id @default(uuid())
  name             String
  subscriptionPlan String   @default("ENTERPRISE") // FREE, PRO, ENTERPRISE
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users    User[]
  zones    Zone[]
  vehicles Vehicle[]
  alerts   Alert[]
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  role           String   @default("VIEWER") // SUPER_ADMIN, CITY_ADMIN, OPS_MANAGER, ANALYST, FIELD_OPERATOR, VIEWER
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Zone {
  id               String   @id @default(uuid())
  name             String
  geometry         String?  // Stored as JSON string
  cleanlinessScore Float    @default(100.0)
  organizationId   String
  
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bins         Bin[]
}

model Bin {
  id               String   @id @default(uuid())
  locationLat      Float
  locationLng      Float
  capacity         Float    // In liters
  currentFillLevel Float    // 0 to 100 percentage
  type             String   @default("GENERAL") // GENERAL, RECYCLING, COMPOST, HAZARDOUS
  lastCollected    DateTime?
  zoneId           String

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id             String   @id @default(uuid())
  capacity       Float
  status         String   @default("IDLE") // IDLE, ON_ROUTE, MAINTENANCE
  lat            Float
  lng            Float
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routes       Route[]
}

model Route {
  id                String   @id @default(uuid())
  waypoints         String   // Array of points or bin IDs stored as JSON string
  estimatedDuration Float    // In minutes
  emissionsSaved    Float    // In kg
  createdAt         DateTime @default(now())
  vehicleId         String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Alert {
  id             String   @id @default(uuid())
  type           String   // OVERFLOW_RISK, SERVICE_GAP, INCIDENT
  severity       String   // LOW, MEDIUM, HIGH, CRITICAL
  message        String
  timestamp      DateTime @default(now())
  resolved       Boolean  @default(false)
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

