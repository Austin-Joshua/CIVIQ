PORT=5000
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:3000

# MongoDB (NoSQL) — no SQL database is used by this API
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=civiq

SOCKETIO_ENABLED=false
SOCKETIO_PORT=5001

SEED_ORGANIZATION_NAME=CIVIQ Demo City
SEED_ADMIN_PASSWORD=civiq2026
BOOTSTRAP_LOGIN_USER=true

# Security monitoring (Telegram alerts optional; blocks work without Telegram)
SECURITY_MONITOR_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_INTERVAL_SEC=3
SECURITY_BLOCK_IP_MINUTES=30
SECURITY_BLOCK_USER_MINUTES=60
# Background detection sweep interval (seconds); rules evaluated on each tick when monitoring ON
SECURITY_DETECTION_INTERVAL_SEC=10
# Total API events per IP per rolling minute before "excessive_requests"
SECURITY_MAX_REQUESTS_PER_IP_PER_MIN=100
SECURITY_BACKUP_DATABASE_NAME=civiq_backup
SECURITY_BACKUP_SYNC_INTERVAL_SEC=30

# Real-time ML security (Python ai-services). When set, traffic is batched async to /api/security/ml/classify
SECURITY_ML_BASE_URL=http://127.0.0.1:8000
SECURITY_ML_BATCH_SIZE=8
SECURITY_ML_BATCH_WAIT_MS=50
SECURITY_ML_HTTP_TIMEOUT_MS=1500
